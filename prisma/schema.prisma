generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  phone        String  @unique
  country      String
  state        String
  bio          String?
  creator      Boolean @default(false)
  premium      Boolean @default(false)
  password     String
  profileImage String?

  podcasts   Podcast[]
  audiobooks Audiobook[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Podcast {
  id                String   @id @default(uuid())
  podcastName       String
  podcastImage      String
  genres            String[]
  keywords          String[]
  podcastParts      Json[]
  userId            String
  user              User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Audiobook {
  id                  String   @id @default(uuid())
  audiobookName       String
  audiobookImage      String
  genres              String[]
  keywords            String[]
  audiobookParts      Json[]
  userId              String
  user                User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
