generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                String  @id @default(uuid())
  name              String
  email             String  @unique
  phone             String  @unique
  country           String
  state             String
  bio               String?
  creator           Boolean @default(false)
  premium           Boolean @default(false)
  isVerified        Boolean @default(false)
  verificationToken String?
  password          String
  profileImage      String?

  Audio            Audio[]
  liveTalksAsHost  LiveTalk[]            @relation("HostUser")
  liveTalksAsGuest LiveTalkParticipant[] @relation("GuestUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Audio {
  id         String   @id @default(uuid())
  title      String
  slug       String   @unique
  coverImage String
  category   String
  genres     String[]
  keywords   String[]
  parts      Json[]
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LiveTalk {
  id           String                @id @default(uuid())
  hostUserId   String
  status       String?
  title        String
  slug         String                @unique
  genres       String[]
  record       Boolean               @default(false)
  hostUser     User                  @relation("HostUser", fields: [hostUserId], references: [id])
  participants LiveTalkParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LiveTalkParticipant {
  id              String   @id @default(uuid())
  liveTalkId      String
  guestUserId     String
  accepted        Boolean  @default(false)
  liveTalk        LiveTalk @relation(fields: [liveTalkId], references: [id])
  guestUser       User     @relation("GuestUser", fields: [guestUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
